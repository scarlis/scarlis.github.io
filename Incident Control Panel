<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Incident Control Panel</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        :root {
            --bg-black: #000000;
            --text-white: #ffffff;
            --text-blue: #e0f2ff;
            --text-red: #ffcccc;
            --btn-gray: #444444;
            --btn-orange: #ff8c00;
        }

        body, html {
            margin: 0; padding: 0;
            height: 100%; width: 100%;
            font-family: "Arial Narrow", sans-serif;
            overflow: hidden;
            background: var(--bg-black);
        }

        /* Top Bar */
        #top-bar {
            width: 100%; height: 60px;
            background: var(--bg-black);
            color: var(--text-white);
            display: flex; align-items: center;
            padding: 0 15px; box-sizing: border-box;
            border-bottom: 1px solid #333;
            justify-content: space-between;
        }

        .bar-item { margin-right: 20px; font-size: 14px; }
        
        button {
            cursor: pointer; padding: 5px 12px;
            border: none; border-radius: 3px;
        }

        #btn-add-sector { background: var(--btn-gray); color: white; }
        #btn-add-sector.active { background: var(--btn-orange); }

        /* Main Layout */
        #main-container {
            display: flex; height: calc(100vh - 60px); width: 100%;
        }

        /* Left Half: Map */
        #map-wrapper {
            flex: 1; position: relative;
            border-right: 1px solid #333;
        }
        #map { height: 100%; width: 100%; }
        #coords-display {
            position: absolute; bottom: 5px; left: 5px;
            background: rgba(0,0,0,0.7); color: white;
            padding: 2px 8px; font-size: 11px; z-index: 1000;
        }

        /* Right Half: Units & Log */
        #sidebar {
            flex: 1; display: flex; flex-direction: column;
            background: var(--bg-black); overflow-y: auto;
        }

        #unit-section {
            padding: 15px; color: var(--text-blue);
            min-height: 40%;
        }

        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th { text-align: left; border-bottom: 1px solid #444; padding: 8px; }
        td { padding: 8px; border-bottom: 1px solid #222; }

        .unit-desc {
            max-width: 100px; white-space: nowrap;
            overflow: hidden; text-overflow: ellipsis;
            display: inline-block;
        }
        .unit-desc:hover { overflow: visible; white-space: normal; background: #111; }

        /* Log Section */
        #log-section {
            flex-grow: 1; padding: 15px;
            border-top: 2px solid #333;
            color: var(--text-red); font-size: 13px;
        }

        #log-display {
            height: 200px; overflow-y: scroll;
            border: 1px solid #222; margin-top: 10px;
            padding: 5px; line-height: 1.4;
        }

        /* Modals */
        .modal {
            display: none; position: fixed; z-index: 2000;
            top: 50%; left: 50%; transform: translate(-50%, -50%);
            background: #222; color: white; padding: 20px;
            border: 1px solid #555; width: 300px;
        }
        .modal input { width: 90%; margin-bottom: 10px; padding: 5px; }

        .sector-label {
            background: transparent; border: none;
            color: white; font-weight: bold; text-shadow: 1px 1px 2px black;
        }
    </style>
</head>
<body>

    <div id="top-bar">
        <div class="bar-item" id="live-clock">00:00:00</div>
        <div class="bar-item" id="weather-info">Weather: Loading...</div>
        <div class="bar-item">
            Incident Description: <button id="btn-incident" onclick="openModal('incident')">None</button>
        </div>
        <div class="bar-item">
            Operator: <button id="btn-operator" onclick="openModal('operator')">Unassigned</button>
        </div>
        <button id="btn-add-sector" onclick="toggleSectorMode()">Add Sector</button>
    </div>

    <div id="main-container">
        <div id="map-wrapper">
            <div id="map"></div>
            <div id="coords-display">Lat: 0, Lng: 0</div>
        </div>

        <div id="sidebar">
            <div id="unit-section">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <h3 style="margin:0">Response Teams</h3>
                    <button onclick="addUnitRow()" style="background: #008cba; color: white; font-weight: bold;">+</button>
                </div>
                <table id="unit-table">
                    <thead>
                        <tr>
                            <th>Unit Desc.</th>
                            <th>Personnel</th>
                            <th>SitRep</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>

            <div id="log-section">
                <h3 style="margin:0">Incident Log</h3>
                <button onclick="copyLog()" style="margin-top: 5px;">Backup Log</button>
                <div id="log-display"></div>
            </div>
        </div>
    </div>

    <div id="modal-overlay" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1999;" onclick="closeModal()"></div>
    <div id="input-modal" class="modal">
        <h4 id="modal-title">Enter Info</h4>
        <input type="text" id="modal-input">
        <button onclick="submitModal()">Confirm</button>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        // --- State Management ---
        let operatorId = "Unassigned";
        let incidentDesc = "None";
        let isSectorMode = false;
        let sectorPoints = [];
        let activeModalType = "";
        let currentTargetRow = null;

        // --- Initialization ---
        const map = L.map('map').setView([-33.8688, 151.2093], 13); // Default Sydney
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OSM'
        }).addTo(map);

        // Geolocation
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(pos => {
                map.setView([pos.coords.latitude, pos.coords.longitude], 14);
            });
        }

        // --- Clock & Weather ---
        setInterval(() => {
            const now = new Date();
            document.getElementById('live-clock').innerText = now.toTimeString().split(' ')[0];
        }, 1000);

        async function fetchWeather() {
            try {
                // Using a public proxy/mock logic for BOM as BOM requires specialized keys
                // Replace URL with your actual BOM API or proxy endpoint
                const center = map.getCenter();
                const response = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${center.lat}&longitude=${center.lng}&current_weather=true`);
                const data = await response.json();
                const w = data.current_weather;
                const windDir = getCardinalDirection(w.winddirection);
                document.getElementById('weather-info').innerText = 
                    `${w.temperature.toFixed(1)}°C | ${w.windspeed}km/h ${windDir}`;
            } catch (e) {
                console.error("Weather fetch failed");
            }
        }
        setInterval(fetchWeather, 120000);
        fetchWeather();

        function getCardinalDirection(angle) {
            const directions = ['N', 'NE', 'E', 'SE', 'S', 'SW', 'W', 'NW'];
            return directions[Math.round(angle / 45) % 8];
        }

        // --- Map Interaction ---
        map.on('mousemove', (e) => {
            document.getElementById('coords-display').innerText = 
                `Lat: ${e.latlng.lat.toFixed(5)}, Lng: ${e.latlng.lng.toFixed(5)}`;
        });

        map.on('click', (e) => {
            if (!isSectorMode) return;
            sectorPoints.push([e.latlng.lat, e.latlng.lng]);
            L.circleMarker(e.latlng, { radius: 3, color: 'red' }).addTo(map);
        });

        function toggleSectorMode() {
            const btn = document.getElementById('btn-add-sector');
            if (!isSectorMode) {
                isSectorMode = true;
                btn.classList.add('active');
                sectorPoints = [];
            } else {
                completeSector();
                isSectorMode = false;
                btn.classList.remove('active');
            }
        }

        function completeSector() {
            if (sectorPoints.length === 0) return;
            
            const name = prompt("Enter Sector Name:");
            if (!name) return;

            let logMsg = `Sector Created: ${name}`;
            
            if (sectorPoints.length === 1) {
                logMsg += ` (Point: ${sectorPoints[0][0].toFixed(4)}, ${sectorPoints[0][1].toFixed(4)})`;
                L.marker(sectorPoints[0]).addTo(map).bindPopup(name).openPopup();
            } else {
                const poly = L.polygon(sectorPoints, {
                    color: 'red',
                    fillColor: 'blue',
                    fillOpacity: 0.3
                }).addTo(map);
                
                const center = poly.getBounds().getCenter();
                L.marker(center, { icon: L.divIcon({ className: 'sector-label', html: name }) }).addTo(map);

                poly.on('click', () => {
                    const action = prompt("Type 'rename' or 'delete' for sector: " + name);
                    if(action === 'delete') { map.removeLayer(poly); addLog(`Deleted Sector: ${name}`); }
                });
            }
            addLog(logMsg);
        }

        // --- Log Logic ---
        function addLog(msg) {
            const logDisplay = document.getElementById('log-display');
            const timestamp = new Date().toLocaleTimeString();
            const entry = `[${timestamp}] ${msg}`;
            
            const div = document.createElement('div');
            div.innerText = entry;
            logDisplay.prepend(div);

            const logs = JSON.parse(localStorage.getItem('incidentLogs') || "[]");
            logs.push(entry);
            localStorage.setItem('incidentLogs', JSON.stringify(logs));
        }

        function copyLog() {
            const logs = JSON.parse(localStorage.getItem('incidentLogs') || "[]");
            navigator.clipboard.writeText(logs.join('\n'));
            alert("Log copied to clipboard");
        }

        // --- Unit Table ---
        function addUnitRow() {
            const table = document.getElementById('unit-table').getElementsByTagName('tbody')[0];
            const row = table.insertRow();
            
            row.innerHTML = `
                <td><span class="unit-desc" contenteditable="true" onblur="addLog('Unit Desc Updated')">New Unit...</span></td>
                <td>
                    <select onchange="addLog('Personnel changed to ' + this.value)">
                        ${Array.from({length: 50}, (_, i) => `<option value="${i+1}">${i+1}</option>`).join('')}
                    </select>
                </td>
                <td><button onclick="startSitRep(this)">00:00</button></td>
            `;
            addLog("Added new Response Team row");
        }

        function startSitRep(btn) {
            if (btn.dataset.interval) clearInterval(btn.dataset.interval);
            let sec = 0;
            btn.dataset.interval = setInterval(() => {
                sec++;
                let m = Math.floor(sec / 60).toString().padStart(2, '0');
                let s = (sec % 60).toString().padStart(2, '0');
                btn.innerText = `${m}:${s}`;
            }, 1000);
            addLog("SitRep Timer Reset for Unit");
        }

        // --- Modal Control ---
        function openModal(type) {
            activeModalType = type;
            document.getElementById('input-modal').style.display = 'block';
            document.getElementById('modal-overlay').style.display = 'block';
            document.getElementById('modal-title').innerText = type === 'incident' ? 'Incident Description' : 'Operator ID';
        }

        function closeModal() {
            document.getElementById('input-modal').style.display = 'none';
            document.getElementById('modal-overlay').style.display = 'none';
        }

        function submitModal() {
            const val = document.getElementById('modal-input').value;
            if (activeModalType === 'incident') {
                incidentDesc = val;
                document.getElementById('btn-incident').innerText = val;
                addLog(`Incident Description changed to: ${val}`);
            } else {
                operatorId = val;
                document.getElementById('btn-operator').innerText = val;
                addLog(`Operator ID changed to: ${val}`);
            }
            closeModal();
            document.getElementById('modal-input').value = "";
        }

        // Load existing logs
        window.onload = () => {
            const logs = JSON.parse(localStorage.getItem('incidentLogs') || "[]");
            const logDisplay = document.getElementById('log-display');
            logs.forEach(l => {
                const div = document.createElement('div');
                div.innerText = l;
                logDisplay.prepend(div);
            });
        };
    </script>
</body>
</html>
